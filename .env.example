# Copiá este archivo a .env.local para desarrollo local.
# Para producción (GitHub Pages) estos valores van como Secrets
# en Settings → Secrets and variables → Actions.

# ─── Supabase ───
VITE_SUPABASE_URL=https://<tu-project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<tu-anon-key>

# ─── Permisos admin ───
# Lista separada por comas — coincide con la función SQL is_portal_admin
# en supabase/migrations/003_*.
VITE_ADMIN_EMAILS=email1@dominio.com,email2@dominio.com
VITE_ADMIN_USER_IDS=<uuid1>,<uuid2>

# ─── Build ───
# Subpath donde se sirve el sitio. Usalo solo si lo deployás en
# https://<user>.github.io/<repo>/. Para dominio custom o user-page,
# dejalo en "/".
# VITE_BASE_PATH=/Estetica-Gestion/

# Empaqueta todo en un único archivo HTML (incrustando JS/CSS).
# Útil para distribuir el preview por email. Rompe routing SPA.
# VITE_SINGLE_FILE=1
